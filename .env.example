# ============================================================
# FARMACIA WEB - Variables de entorno requeridas
# Copia este archivo como .env y llena los valores
# NUNCA subas el archivo .env a un repositorio público
# ============================================================

# ---- SESIONES ----
# Clave secreta para firmar las cookies de sesión (pon cualquier texto largo y aleatorio)
SESSION_SECRET=cambia_esto_por_una_clave_secreta_larga

# ---- GOOGLE SHEETS ----
# ID de tu hoja de cálculo (la parte de la URL: docs.google.com/spreadsheets/d/ESTE_ID/edit)
GOOGLE_SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Email de la cuenta de servicio de Google Cloud (termina en @...iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-cuenta@tu-proyecto.iam.gserviceaccount.com

# Clave privada de la cuenta de servicio (del archivo JSON descargado de Google Cloud)
# Copia el valor de "private_key" incluyendo -----BEGIN PRIVATE KEY----- y -----END PRIVATE KEY-----
# En una sola línea, reemplaza los saltos de línea con \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ---- IA (GROQ) ----
# API key gratuita de Groq: https://console.groq.com
GROQ_API_KEY=gsk_tu_api_key_de_groq_aqui

# ---- SERVIDOR ----
# Puerto del servidor (opcional, por defecto 5000)
PORT=5000
